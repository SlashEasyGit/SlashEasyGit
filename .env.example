# =============================================================================
# Tcharts — .env.example
#
# Copy to .env and fill in. .env is gitignored.
# In production, ECS task definitions inject these from AWS Secrets Manager.
# See docs/ENVIRONMENT.md for the full inventory and source-of-truth per env.
# =============================================================================

# ---- shared ----
NODE_ENV=local
LOG_LEVEL=debug
BUILD_SHA=local

# =============================================================================
# apps/api  (NestJS HTTP)
# =============================================================================

PORT=8080

# Postgres — points at the docker-compose Postgres for local dev
DATABASE_URL=postgres://tcharts:tcharts@localhost:5432/tcharts_dev

# Redis — points at the docker-compose Redis for local dev
REDIS_URL=redis://localhost:6379/0

# JWT — generate dev keys with:
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Paste below as single-line PEM (replace newlines with \n) OR as base64.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_COST=12

# Cloudflare R2 — get from Cloudflare dashboard
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tcharts-dev

# Twilio Verify — test creds work for dev signups
# https://www.twilio.com/docs/iam/test-credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Email
# In local dev, point at MailHog (from docker-compose) which catches all outbound mail
SES_REGION=us-east-1
SES_FROM_ADDRESS=noreply@localhost.local

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Sentry — leave empty in local; populate in staging/prod
SENTRY_DSN=

# =============================================================================
# apps/worker
# =============================================================================

WORKER_CONCURRENCY_DEFAULT=5
WORKER_AUDIT_FLUSH_INTERVAL_MS=5000

# =============================================================================
# apps/web  (Next.js)
# =============================================================================

# Public — baked into client bundle at build time
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Server-only — used by RSC + route handlers
INTERNAL_API_URL=http://localhost:8080
COOKIE_DOMAIN=localhost
SESSION_SECRET=change-me-in-production-this-is-only-for-local-do-not-use-in-prod
