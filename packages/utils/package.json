{
  "name": "@tcharts/utils",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@tcharts/config": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
