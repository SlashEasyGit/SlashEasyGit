{
  "name": "@tcharts/contracts",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./openapi": "./src/openapi.yaml"
  },
  "files": ["dist", "src/openapi.yaml"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "spectral lint src/openapi.yaml",
    "generate": "echo 'TODO: openapi-typescript src/openapi.yaml -o src/generated/types.ts'",
    "test": "vitest run",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.14.2",
    "@tcharts/config": "workspace:*",
    "@types/node": "^20.14.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
