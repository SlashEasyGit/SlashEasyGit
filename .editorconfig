# EditorConfig — see https://editorconfig.org
# Enforced uniform formatting independent of editor / OS.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.md]
trim_trailing_whitespace = false  # Markdown uses trailing spaces for line breaks

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.prisma]
indent_size = 2
